{
  "schemaVersion": 1,
  "id": "miningtrackeraddon",
  "version": "${version}",
  "name": "MMM",
  "description": "A Tweakeroo-style companion addon that adds mining tracking, HUD stats, projects, goals, notifications, and session summaries.",
  "authors": [
    "Shekel"
  ],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.miningtrackeraddon.MiningTrackerAddon"
    ],
    "modmenu": [
      "com.miningtrackeraddon.gui.ModMenuCompat"
    ]
  },
  "mixins": [
    "miningtrackeraddon.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.9",
    "fabric-api": "*",
    "minecraft": "${minecraft_dependency}",
    "malilib": ">=0.23.1",
    "tweakeroo": "*"
  }
}
